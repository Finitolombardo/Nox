    {
      "parameters": {
        "jsCode": "const rawItems = $input.all().map(i => i.json);\n\nconst num = (v) => (v === null || v === undefined || v === '' ? 0 : Number(v)) || 0;\n\n// dedupe by page id\nconst seen = new Set();\nconst items = [];\nfor (const it of rawItems) {\n  const id = it.id || it.pageId || it.property_id;\n  if (id && seen.has(id)) continue;\n  if (id) seen.add(id);\n  items.push(it);\n}\n\nfunction score(m) {\n  // P = Positive-Intent-Rate in % (robust fallback)\n  const sends = Math.max(num(m.property_sends), num(m.sends), 0);\n  const posCount = Math.max(num(m.property_positive_count), num(m.positive_count), 0);\n  const P = sends > 0 ? (posCount / sends) * 100 : 0;\n\n  // R = ReplyRate in %\n  const R = Math.max(num(m.property_reply_rate), num(m.reply_rate), 0);\n\n  // O = OpenRate in %\n  const O = Math.max(num(m.property_open_rate), num(m.open_rate), 0);\n\n  // Cash-Score v2\n  const S = (0.6 * P) + (0.25 * R) + (0.15 * O);\n\n  return {\n    S,\n    P,\n    R,\n    O,\n    sends,\n    posCount,\n  };\n}\n\nconst scored = items.map(m => {\n  const r = score(m);\n  return {\n    ...m,\n    cash_score: Number(r.S.toFixed(4)),\n    positive_rate: Number(r.P.toFixed(4)),\n    reply_rate_eval: Number(r.R.toFixed(4)),\n    open_rate_eval: Number(r.O.toFixed(4)),\n    eval_sends: r.sends,\n    eval_positive_count: r.posCount,\n    eval_score: Number(r.S.toFixed(4)),\n  };\n});\n\nif (scored.length < 2) {\n  return scored.map(m => ({\n    json: {\n      ...m,\n      eval_can_compare: false,\n      eval_outcome: 'Pending',\n      eval_winner_id: null,\n      eval_reason: `Batch incomplete: expected 2 mutations, got ${scored.length}`,\n    }\n  }));\n}\n\nscored.sort((a,b) => b.cash_score - a.cash_score);\nconst winner = scored[0];\n\nreturn scored.map(m => ({\n  json: {\n    ...m,\n    eval_can_compare: true,\n    eval_winner_id: winner?.id || null,\n    eval_outcome: (m.id === winner?.id) ? 'Winner' : 'Loser',\n    eval_reason: 'CashScore v2: S=(0.6*P)+(0.25*R)+(0.15*O)',\n  }\n}));"
      },
