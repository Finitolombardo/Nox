    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map((item) => {\n  const j = item.json || {};\n  const ctx = j; // Kontext behalten\n\n  const pitchPage = j.pitchPage || {};\n  const pitchVariant = j.pitchVariant || {};\n\n  const replyTexts = Array.isArray(pitchVariant.replyTexts) ? pitchVariant.replyTexts : [];\n  const positiveReplies = Array.isArray(pitchVariant.positiveReplies) ? pitchVariant.positiveReplies : [];\n\n  const hasReplies = replyTexts.length > 0;\n\n  return {\n    json: {\n      ...ctx, // ✅ ALLES behalten (Badge-ID, whatever du vorher gesetzt hast)\n\n      // IDs\n      mutationLogId: pitchPage.id || ctx.mutationLogId || null,\n      pitchVariantId: pitchVariant.pitchVariantId || ctx.pitchVariantId || null,\n\n      // Stats (aus PitchVariant)\n      pitchVariant, // falls du es später brauchst\n      sends: Number(pitchVariant.property_sends ?? 0),\n      opens: Number(pitchVariant.property_opens ?? 0),\n      clicks: Number(pitchVariant.property_clicks ?? 0),\n      replies: Number(pitchVariant.property_replies ?? 0),\n      open_rate: Number(pitchVariant.property_open_rate ?? 0),\n      reply_rate: Number(pitchVariant.property_reply_rate ?? 0),\n      positive_count: positiveReplies.length,\n\n      // Flags\n      hasReplies,\n      positiveReplies,\n      replyTexts,\n    }\n  };\n});"
      },
