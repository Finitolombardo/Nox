    {
      "parameters": {
        "jsCode": "const now = new Date();\n\nconst items = $input.all();\nconst due = [];\n\nfor (const it of items) {\n  // ✅ Works with flattened Notion output (your screenshot)\n  const d =\n    it.json.property_eval_due_at?.start\n    || it.json.properties?.Eval_Due_At?.date?.start\n    || it.json.properties?.[\"Eval_Due_At\"]?.date?.start;\n\n  const isFinal =\n    it.json.property_is_final\n    ?? it.json.properties?.IsFinal?.checkbox\n    ?? it.json.properties?.[\"IsFinal\"]?.checkbox\n    ?? false;\n\n  if (isFinal) continue;\n  if (!d) continue;\n\n  const dueAt = new Date(d);\n  if (dueAt <= now) due.push(it);\n}\n\n// IMPORTANT: return array of items\nreturn due;"
      },
